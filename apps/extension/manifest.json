{
  "manifest_version": 3,
  "name": "IG Farm",
  "version": "1.0",
  "description": "Collect Instagram profile data",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://instagram.com/*",
    "*://www.instagram.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://www.instagram.com/*"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
